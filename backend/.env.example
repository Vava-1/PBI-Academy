# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/pbi_db
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/pbi_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# AI/LLM
OPENAI_API_KEY=sk-your-openai-key
ABACUS_AI_API_KEY=your-abacus-key
ABACUS_AI_BASE_URL=https://api.abacus.ai

# File Storage
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Payment
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_PREMIUM=price_xxx

# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
