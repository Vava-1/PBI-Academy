# ============================================
# PBI Academy — Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# Server Configuration
PORT=8080
NODE_ENV=production

# Supabase Configuration (PostgreSQL Database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long

# OpenAI API (for AI Tutor)
OPENAI_API_KEY=sk-...

# Flutterwave Configuration (for payments - MTN Mobile Money)
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxx
FLUTTERWAVE_WEBHOOK_SECRET=your-webhook-secret
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxx

# Daily.co API (for live video classes)
DAILY_API_KEY=...

# Resend Email API
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=noreply@pbiacademy.com

# Frontend URL (for CORS and redirects)
FRONTEND_URL=https://pbiacademy.com
ALLOWED_ORIGINS=https://pbiacademy.com,https://www.pbiacademy.com

# Security
BCRYPT_ROUNDS=10
SESSION_TIMEOUT=3600

# Logging
LOG_LEVEL=info
