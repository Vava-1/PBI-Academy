# ============================================
# PBI Academy — Frontend Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend API URL (Railway deployment)
VITE_API_URL=https://api.pbiacademy.com/api

# Flutterwave Configuration (for payments)
VITE_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxx
VITE_FLUTTERWAVE_ENCRYPTION_KEY=your-encryption-key

# Application Configuration
VITE_SITE_URL=https://pbiacademy.com
VITE_APP_NAME=PBI Academy
VITE_DEFAULT_CURRENCY=RWF

# Feature Flags
VITE_ENABLE_PAYMENTS=true
VITE_ENABLE_AI_TUTOR=true
VITE_ENABLE_LIVE_CLASSES=true
